<% layout("/layouts/boilerplate.ejs") %>


<!-- Error: layout was written twice. -->

<section class="container py-5">

    <!-- Heading -->

    <div class="d-flex justify-content-between align-items-center mb-5">

        <div>

            <h1 class="fw-bold mb-1">
                Explore Stays
            </h1>

            <p class="text-muted mb-0">
                Find unique places to stay around the world.
            </p>

        </div>

        <a
            href="/stays/new"
            class="btn btn-dark rounded-pill px-4"
        >
            Add Stay
        </a>

    </div>

    <!-- Stay Grid -->

    <div class="row g-4">

        <% for(let stay of stays) { %>

            <div class="col-md-6 col-lg-4">

                <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 stay-card">

                    <!-- Image -->

                    <img
                        src="<%= (stay.images && stay.images[0]) ? stay.images[0].url : 'https://via.placeholder.com/800x600?text=No+image' %>"
                        class="card-img-top"
                        alt="stay image"
                        style="height: 240px; object-fit: cover;"
                    >

                    <!-- Card Body -->

                    <div class="card-body d-flex flex-column">

                        <!-- Top -->

                        <div class="d-flex justify-content-between align-items-start mb-2">

                            <h5 class="fw-bold mb-0">

                                <%= stay.name %>

                            </h5>

                            <% if(stay.isAvailable) { %>

                                <span class="badge bg-success rounded-pill">
                                    Available
                                </span>

                            <% } else { %>

                                <span class="badge bg-danger rounded-pill">
                                    Booked
                                </span>

                            <% } %>

                        </div>

                        <!-- Location -->

                        <p class="text-muted mb-2">

                            📍 <%= stay.location %>

                        </p>

                        <!-- Description -->

                        <p class="text-secondary small flex-grow-1">

                            <%= stay.description.substring(0, 90) %>...

                        </p>

                        <!-- Type & Capacity -->

                        <div class="d-flex justify-content-between mb-3">

                            <span class="badge bg-light text-dark border">

                                <%= stay.type %>

                            </span>

                            <span class="text-muted small">

                                👥 <%= stay.capacity %> Guests

                            </span>

                        </div>

                        <!-- Bottom -->

                        <div class="d-flex justify-content-between align-items-center">

                            <div>

                                <span class="fw-bold fs-5">

                                    ₹<%= stay.price %>

                                </span>

                                <span class="text-muted small">
                                    / night
                                </span>

                            </div>

                            <a
                                href="/stays/<%= stay._id %>"
                                class="btn btn-dark rounded-pill px-4"
                            >
                                View
                            </a>

                        </div>

                    </div>

                </div>

            </div>

        <% } %>

    </div>
    

</section>
<style>

.stay-card{
    transition: all 0.3s ease;
}

.stay-card:hover{
    transform: translateY(-6px);
    box-shadow: 0 14px 30px rgba(0,0,0,0.12);
}

.card-img-top{
    transition: transform 0.4s ease;
}

.stay-card:hover .card-img-top{
    transform: scale(1.05);
}

</style>

