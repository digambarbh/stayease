<% layout("/layouts/boilerplate.ejs") %>


    <!-- Error: layout was written twice. -->

    <section class="container py-5">

        <!-- Heading -->

        <div class="d-flex justify-content-between align-items-center mb-5">

            <div>

                <h1 class="fw-bold mb-1">
                    Explore Stays
                </h1>

                <p class="text-muted mb-0">
                    Find unique places to stay around the world.
                </p>

            </div>

            

        </div>

        <!-- Stay Grid -->

        <div class="row g-4">

            <% for(let stay of stays) { %>

                <div class="col-sm-6 col-md-4 col-lg-3">

                    <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 stay-card">

                        <!-- Image -->

                        <img src="<%= (stay.images && stay.images[0]) ? stay.images[0].url : 'https://via.placeholder.com/800x600?text=No+image' %>"
                            class="card-img-top" alt="stay image" style="object-fit: cover;">

                        <!-- Card Body -->

                        <div class="card-body d-flex flex-column">

                            <!-- Top -->

                            <div class="d-flex justify-content-between align-items-start mb-2">

                                <h5 class="fw-bold mb-0">

                                    <%= stay.name %>

                                </h5>

                                <% if(stay.isAvailable) { %>

                                    <span class="badge bg-success rounded-pill">
                                        Available
                                    </span>

                                    <% } else { %>

                                        <span class="badge bg-danger rounded-pill">
                                            Booked
                                        </span>

                                        <% } %>

                            </div>

                            <!-- Location -->

                            <p class="text-muted mb-2">

                                📍 <%= stay.location %>

                            </p>

                            <!-- Description -->

                            <p class="text-secondary small flex-grow-1">

                                <%= stay.description.substring(0, 90) %>...

                            </p>

                            <!-- Type & Capacity -->

                            <div class="d-flex justify-content-between mb-3">

                                <span class="badge bg-light text-dark border">

                                    <%= stay.type %>

                                </span>

                                <span class="text-muted small">

                                    👥 <%= stay.capacity %> Guests

                                </span>

                            </div>

                            <!-- Bottom -->

                            <div class="d-flex justify-content-between align-items-center">

                                <div>

                                    <span class="fw-bold fs-5">

                                        ₹<%= stay.price %>

                                    </span>

                                    <span class="text-muted small">
                                        / night
                                    </span>

                                </div>

                                <a href="/stays/<%= stay._id %>" class="btn btn-dark rounded-pill px-4">
                                    View
                                </a>

                            </div>

                        </div>

                    </div>

                </div>

                <% } %>

        </div>

        <!-- Pagination -->
        <% if (totalPages > 1) { %>
            <nav aria-label="Stay navigation" class="mt-5">
                <ul class="pagination justify-content-center border-0">
                    
                    <% 
                    const getPageUrl = (pageNum) => {
                        let queryParams = [];
                        for (let key in query) {
                            if (key !== 'page' && query[key]) {
                                queryParams.push(encodeURIComponent(key) + '=' + encodeURIComponent(query[key]));
                            }
                        }
                        queryParams.push('page=' + pageNum);
                        return '/stays?' + queryParams.join('&');
                    };
                    %>
                
                    <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                        <a class="page-link text-dark rounded-pill me-2 px-3 fw-bold" href="<%= currentPage > 1 ? getPageUrl(currentPage - 1) : '#' %>" style="border: none; background: <%= currentPage === 1 ? 'transparent' : '#f8f9fa' %>">Previous</a>
                    </li>
                    
                    <% for(let i = 1; i <= totalPages; i++) { %>
                        <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                            <a class="page-link rounded-circle mx-1 d-flex align-items-center justify-content-center fw-bold" href="<%= getPageUrl(i) %>" style="width: 40px; height: 40px; border: none; <%= currentPage === i ? 'background-color: #222222; color: white;' : 'color: #222222; background: transparent;' %>"><%= i %></a>
                        </li>
                    <% } %>
                    
                    <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                        <a class="page-link text-dark rounded-pill ms-2 px-3 fw-bold" href="<%= currentPage < totalPages ? getPageUrl(currentPage + 1) : '#' %>" style="border: none; background: <%= currentPage === totalPages ? 'transparent' : '#f8f9fa' %>">Next</a>
                    </li>
                </ul>
            </nav>
        <% } %>

    </section>
    <style>
        /* Airbnb-Style Global Enhancements */
        body {
            background-color: #ffffff;
        }

        /* Explore Stays Heading Styles */
        .container h1 {
            font-size: 2rem;
            font-weight: 600 !important;
            letter-spacing: -0.02em;
            color: #222222;
            margin-bottom: 0.5rem !important;
            background: none;
            -webkit-background-clip: unset;
            -webkit-text-fill-color: unset;
        }

        .container p.text-muted {
            font-size: 1rem;
            color: #717171 !important;
            font-weight: 400;
        }

        /* Top Action Button */
        .container>.d-flex>.btn-dark.rounded-pill {
            padding: 10px 20px !important;
            font-size: 0.9rem;
            font-weight: 600;
            background: #222222;
            color: white;
            border: none;
            box-shadow: none;
            transition: transform 0.15s ease;
        }

        .container>.d-flex>.btn-dark.rounded-pill:hover {
            transform: scale(1.02);
            background-color: #000000;
            box-shadow: none;
        }

        /* Glide Up Animation - Remove or keep subtle */
        @keyframes glideUp {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Premium Airbnb Stay Cards */
        .stay-card {
            border: none !important;
            border-radius: 0 !important;
            overflow: visible;
            background-color: transparent !important;
            box-shadow: none !important;
            transition: none !important;
            animation: glideUp 0.4s ease both;
            position: relative;
            /* Essential for clickable overlay trick */
        }

        .stay-card:hover {
            transform: none !important;
            box-shadow: none !important;
            border-color: transparent !important;
        }

        /* Image styling - identical to Airbnb */
        .card-img-top {
            border-radius: 12px !important;
            height: 280px !important;
            object-fit: cover;
            margin-bottom: 12px;
            transition: none !important;
        }

        .stay-card:hover .card-img-top {
            transform: none !important;
        }

        .stay-card .card-body {
            padding: 0 !important;
        }

        /* Title & Layout */
        .stay-card .d-flex.justify-content-between.align-items-start.mb-2 {
            margin-bottom: 0 !important;
        }

        .stay-card h5.fw-bold {
            color: #222222;
            font-size: 1rem;
            font-weight: 600 !important;
            line-height: 1.2;
            margin-bottom: 2px !important;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 80%;
        }

        /* Location */
        .stay-card p.text-muted {
            font-size: 0.95rem;
            font-weight: 400;
            color: #717171 !important;
            margin-bottom: 2px !important;
        }

        /* Description (Make it 1 line like Airbnb's secondary text) */
        .stay-card .text-secondary.small {
            font-size: 0.95rem;
            color: #717171 !important;
            margin-bottom: 2px !important;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            line-height: 1.2;
        }

        /* Type & Capacity */
        .stay-card .d-flex.justify-content-between.mb-3 {
            border-top: none;
            padding-top: 0;
            margin-bottom: 8px !important;
            justify-content: flex-start !important;
            gap: 8px;
        }

        /* Transform badges into simple text separated by dot */
        .stay-card .badge {
            font-size: 0.95rem;
            padding: 0;
            font-weight: 400;
            border-radius: 0 !important;
            background: transparent !important;
            border: none !important;
            color: #717171 !important;
            letter-spacing: 0;
        }

        .stay-card .badge::after {
            content: " • ";
            margin-left: 8px;
            color: #717171;
        }

        .stay-card .d-flex.mb-3 .text-muted.small {
            font-size: 0.95rem;
            font-weight: 400;
            color: #717171 !important;
        }

        /* Pricing Area */
        .stay-card .d-flex.justify-content-between.align-items-center {
            justify-content: flex-start !important;
            margin-top: 4px;
        }

        .stay-card span.fw-bold.fs-5 {
            font-size: 1rem !important;
            font-weight: 600 !important;
            color: #222222;
            letter-spacing: 0;
        }

        .stay-card .align-items-center .text-muted.small {
            font-size: 1rem !important;
            color: #222222 !important;
            font-weight: 400 !important;
            margin-left: 4px;
        }

        /* 
           The Airbnb Trick:
           Hide the "View" button visually, but stretch it over the entire card 
           so the whole card becomes a clickable link!
        */
        .stay-card .card-body .btn-dark {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            opacity: 0;
            z-index: 10;
            cursor: pointer;
            padding: 0 !important;
            border: none !important;
            border-radius: 0 !important;
        }
    </style>