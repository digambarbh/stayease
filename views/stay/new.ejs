<% layout("/layouts/boilerplate.ejs") %>

    <section class="container py-5">

        <div class="row justify-content-center">

            <div class="col-lg-8">

                <!-- Card -->

                <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

                    <!-- Header -->

                    <div class="bg-dark text-white p-4">

                        <h2 class="fw-bold mb-1">
                            Register New Stay
                        </h2>

                        <p class="mb-0 text-light">
                            Add your property and start hosting guests.
                        </p>

                    </div>

                    <!-- Form Body -->

                    <div class="card-body p-5">

                        <form action="/stays/new" method="POST" enctype="multipart/form-data" novalidate
                            class="validated-form">

                            <!-- Stay Name -->

                            <div class="mb-4">

                                <label class="form-label fw-semibold">
                                    Stay Name
                                </label>

                                <input type="text" name="stay[name]" class="form-control form-control-lg rounded-3"
                                    placeholder="Ocean View Villa" required>

                            </div>

                            <!-- Description -->

                            <div class="mb-4">

                                <label class="form-label fw-semibold">
                                    Description
                                </label>

                                <textarea name="stay[description]" rows="5" class="form-control rounded-3"
                                    placeholder="Describe your property..." required></textarea>

                            </div>

                            <!-- Price & Capacity -->

                            <div class="row">

                                <div class="col-md-6 mb-4">

                                    <label class="form-label fw-semibold">
                                        Price Per Night
                                    </label>

                                    <div class="input-group input-group-lg">

                                        <span class="input-group-text">
                                            ₹
                                        </span>

                                        <input type="number" name="stay[price]" class="form-control" placeholder="2500"
                                            required>

                                    </div>

                                </div>

                                <div class="col-md-6 mb-4">

                                    <label class="form-label fw-semibold">
                                        Capacity
                                    </label>

                                    <input type="number" name="stay[capacity]"
                                        class="form-control form-control-lg rounded-3" placeholder="4 Guests" required>

                                </div>

                            </div>

                            <!-- Location -->

                            <div class="mb-4">

                                <label class="form-label fw-semibold">
                                    Location
                                </label>
                                <input type="text" name="stay[location]" class="form-control form-control-lg rounded-3"
                                    placeholder="Nashik, Maharashtra" required>
                            </div>
                            <!-- Image URLs -->
                            <div class="mb-4">

                                <label class="form-label fw-semibold">
                                    Enter Images
                                </label>

                                <input type="file" name="image" class="form-control rounded-3 mb-3" multiple>
                                <small class="text-muted">
                                    Upload multiple scenic images
                                </small>
                            </div>

                            <!-- Stay Type -->

                            <div class="mb-4">

                                <label class="form-label fw-semibold">
                                    Stay Type
                                </label>

                                <select name="stay[type]" class="form-select form-select-lg rounded-3" required>

                                    <option value="">
                                        Select Type
                                    </option>

                                    <option value="apartment">
                                        Apartment
                                    </option>

                                    <option value="villa">
                                        Villa
                                    </option>

                                    <option value="cabin">
                                        Cabin
                                    </option>

                                    <option value="cottage">
                                        Cottage
                                    </option>

                                    <option value="hotel">
                                        Hotel
                                    </option>

                                </select>

                            </div>


                            <!-- Submit Button -->

                            <button type="submit" class="btn btn-dark btn-lg w-100 rounded-3">

                                Publish Stay

                            </button>

                        </form>

                    </div>

                </div>

            </div>

        </div>

    </section>

    <script>
        (() => {
            'use strict'

            // Fetch all the forms we want to apply custom Bootstrap validation styles to
            const forms = document.querySelectorAll('.validated-form')

            // Loop over them and prevent submission
            Array.from(forms).forEach(form => {
                form.addEventListener('submit', event => {
                    if (!form.checkValidity()) {
                        event.preventDefault()
                        event.stopPropagation()
                    }

                    form.classList.add('was-validated')
                }, false)
            })
        })()
    </script>