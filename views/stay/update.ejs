<% layout("/layouts/boilerplate.ejs") %>

<style>
    body {
        background-image: url('https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?q=80&w=2070&auto=format&fit=crop');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        font-family: 'Inter', -apple-system, sans-serif;
    }

    /* Add a subtle dark overlay to the body to make the card pop */
    body::before {
        content: "";
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0, 0, 0, 0.3);
        z-index: -1;
    }

    .form-container {
        max-width: 1000px;
        margin: 2rem auto;
        padding: 0 1rem;
    }

    .custom-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(20px);
        border-radius: 24px;
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.2);
        border: 1px solid rgba(255, 255, 255, 0.5);
        overflow: hidden;
    }

    .card-header-gradient {
        background: linear-gradient(135deg, #111 0%, #333 100%);
        padding: 2rem;
        color: white;
    }

    .form-label {
        font-weight: 700;
        font-size: 0.9rem;
        color: #333;
        margin-bottom: 0.4rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .form-control, .form-select {
        background-color: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 0.8rem 1rem;
        font-size: 1rem;
        transition: all 0.2s ease;
    }

    .form-control:focus, .form-select:focus {
        background-color: #fff;
        border-color: #FF385C;
        box-shadow: 0 0 0 4px rgba(255, 56, 92, 0.1);
    }

    .input-group-text {
        background-color: #f8fafc;
        border: 1px solid #e2e8f0;
        border-right: none;
        color: #64748b;
        font-weight: 600;
        border-top-left-radius: 12px;
        border-bottom-left-radius: 12px;
    }

    .price-input {
        border-left: none;
    }

    .submit-btn {
        background: linear-gradient(to right, #FF385C, #E31C5F);
        color: white;
        border: none;
        padding: 1rem 2rem;
        border-radius: 12px;
        font-size: 1.1rem;
        font-weight: 800;
        width: 100%;
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        box-shadow: 0 8px 20px rgba(227, 28, 95, 0.3);
    }

    .submit-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 25px rgba(227, 28, 95, 0.4);
    }

    /* Grid Layout for compact form */
    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
    }

    @media (max-width: 768px) {
        .form-grid {
            grid-template-columns: 1fr;
            gap: 1rem;
        }
    }
</style>

<div class="form-container">
    <div class="custom-card">
        
        <!-- Header -->
        <div class="card-header-gradient">
            <h2 class="fw-bold mb-1 fs-3">Update Stay</h2>
            <p class="mb-0 text-white-50">Edit your property details and manage availability.</p>
        </div>

        <!-- Form Body -->
        <div class="p-4 p-md-5">
            <form action="/stays/<%= stay._id %>?_method=PATCH" method="POST" enctype="multipart/form-data" novalidate class="validated-form">
                
                <div class="form-grid">
                    
                    <!-- Left Column -->
                    <div class="d-flex flex-column gap-3">
                        
                        <div>
                            <label class="form-label">Stay Name</label>
                            <input type="text" name="stay[name]" class="form-control" placeholder="e.g. Ocean View Villa" value="<%= stay.name %>" required>
                        </div>

                        <div>
                            <label class="form-label">Location</label>
                            <input type="text" name="stay[location]" class="form-control" placeholder="e.g. Nashik, Maharashtra" value="<%= stay.location %>" required>
                        </div>

                        <div class="row g-3">
                            <div class="col-6">
                                <label class="form-label">Price Per Night</label>
                                <div class="input-group">
                                    <span class="input-group-text">₹</span>
                                    <input type="number" name="stay[price]" class="form-control price-input" placeholder="2500" value="<%= stay.price %>" required>
                                </div>
                            </div>
                            <div class="col-6">
                                <label class="form-label">Capacity</label>
                                <div class="input-group">
                                    <input type="number" name="stay[capacity]" class="form-control" placeholder="4" value="<%= stay.capacity %>" required>
                                    <span class="input-group-text" style="border-left:none; border-right:1px solid #e2e8f0; border-top-right-radius:12px; border-bottom-right-radius:12px;">Guests</span>
                                </div>
                            </div>
                        </div>

                        <div>
                            <label class="form-label">Stay Type</label>
                            <select name="stay[type]" class="form-select" required>
                                <option value="apartment" <%=stay.type==="apartment" ? "selected" : "" %>>Apartment</option>
                                <option value="villa" <%=stay.type==="villa" ? "selected" : "" %>>Villa</option>
                                <option value="cabin" <%=stay.type==="cabin" ? "selected" : "" %>>Cabin</option>
                                <option value="cottage" <%=stay.type==="cottage" ? "selected" : "" %>>Cottage</option>
                                <option value="hotel" <%=stay.type==="hotel" ? "selected" : "" %>>Hotel</option>
                            </select>
                        </div>
                        
                        <!-- Availability Switch -->
                        <div class="mt-2 p-3 bg-light rounded-3 border">
                            <div class="form-check form-switch d-flex align-items-center gap-3 m-0">
                                <input class="form-check-input fs-4 m-0" type="checkbox" name="stay[isAvailable]" value="true" <%=stay.isAvailable ? "checked" : "" %>>
                                <label class="form-check-label fw-bold mb-0">Available For Booking</label>
                            </div>
                        </div>

                    </div>

                    <!-- Right Column -->
                    <div class="d-flex flex-column gap-3">
                        
                        <div class="d-flex flex-column">
                            <label class="form-label">Description</label>
                            <textarea name="stay[description]" class="form-control" style="min-height: 120px; resize: none;" placeholder="Describe what makes your property unique and special..." required><%= stay.description %></textarea>
                        </div>

                        <div>
                            <label class="form-label">Current Images</label>
                            <div class="d-flex flex-wrap gap-2 mb-3 bg-light p-3 rounded-3 border">
                                <% if (stay.images && stay.images.length) { %>
                                    <% stay.images.forEach(img => { %>
                                        <div class="position-relative" style="width: 80px;">
                                            <img src="<%= img.url %>" class="img-fluid rounded-3 shadow-sm" style="height: 60px; object-fit: cover;" alt="image">
                                            <div class="form-check mt-1">
                                                <input class="form-check-input shadow-sm" style="transform: scale(1.1);" type="checkbox" name="deleteImages" value="<%= img.filename %>" id="del-<%= img.filename %>">
                                                <label class="form-check-label small fw-bold" for="del-<%= img.filename %>" style="font-size: 0.75rem;">Delete</label>
                                            </div>
                                        </div>
                                    <% }) %>
                                <% } else { %>
                                    <p class="text-muted small mb-0 fw-semibold">No images uploaded.</p>
                                <% } %>
                            </div>

                            <label class="form-label">Upload New Images</label>
                            <input type="file" name="image" class="form-control" style="padding: 0.6rem 1rem;" multiple>
                        </div>

                        <div class="mt-auto pt-3">
                            <button type="submit" class="submit-btn">
                                <i class="fa-solid fa-arrows-rotate me-2"></i> Update Stay
                            </button>
                        </div>

                    </div>

                </div>

            </form>
        </div>
    </div>
</div>

<script>
    (() => {
        'use strict'
        const forms = document.querySelectorAll('.validated-form')
        Array.from(forms).forEach(form => {
            form.addEventListener('submit', event => {
                if (!form.checkValidity()) {
                    event.preventDefault()
                    event.stopPropagation()
                }
                form.classList.add('was-validated')
            }, false)
        })
    })()
</script>