              <path d="M6 9l6 6 6-6" />
            </svg>
          </button>
          <div class="se-dropdown-menu">
            <a href="/stays" class="se-dropdown-item">
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M3 12L12 3l9 9" />
                <path d="M9 21V12h6v9" />
              </svg>
              Browse All
            </a>
            <a href="/stays?type=villa" class="se-dropdown-item">
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <rect x="2" y="7" width="20" height="14" rx="2" />
                <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2" />
              </svg>
              Villas
            </a>
            <a href="/stays?type=apartment" class="se-dropdown-item">
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <rect x="4" y="2" width="16" height="20" rx="1" />
                <path d="M9 22V12h6v10" />
              </svg>
              Apartments
            </a>
            <a href="/stays?type=cabin" class="se-dropdown-item">
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M3 10.5L12 3l9 7.5V20a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1v-9.5z" />
              </svg>
              Cabins
            </a>
            <a href="/stays?type=farmhouse" class="se-dropdown-item">
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M12 2L2 7l10 5 10-5-10-5z" />
                <path d="M2 17l10 5 10-5" />
                <path d="M2 12l10 5 10-5" />
              </svg>
              Farmhouses
            </a>
          </div>
        </div>

        <% if (Role=="host" ) { %>
          <a href="/stays/new" class="se-nav-link">
            <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10" />
              <path d="M12 8v8M8 12h8" />
            </svg>
            Create Stay
          </a>
          <% } %>
            <a href="/user/wishlist" class="se-nav-link">
              <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24">
                <path
                  d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
              </svg>
              Wishlist
            </a>

            <% if (!isLoggedIn) { %>

              <a href="/user/register" class="se-btn-outline">Register</a>
              <a href="/user/login" class="se-btn-primary">Login</a>

