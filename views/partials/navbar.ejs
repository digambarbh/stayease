<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
  :root {
    --se-brand: #FF385C;
    --se-brand-dark: #D93B55;
    --se-dark: #222222;
    --se-muted: #717171;
    --se-border: #DDDDDD;
    --se-surface: #F7F7F7;
    --se-white: #FFFFFF;
    --se-radius: 40px;
    --se-shadow: 0 2px 16px rgba(0, 0, 0, 0.10);
    --se-shadow-lg: 0 8px 32px rgba(0, 0, 0, 0.16);
  }

  * {
    font-family: 'Inter', sans-serif;
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  .se-navbar {
    background: var(--se-white);
    border-bottom: 1px solid var(--se-border);
    position: sticky;
    top: 0;
    z-index: 1000;
  }

  .se-nav-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
    padding: 0 24px;
    gap: 12px;
    max-width: 1280px;
    margin: 0 auto;
  }

  /* ── Logo ── */
  .se-logo {
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
  }

  .se-logo svg {
    color: var(--se-brand);
  }

  .se-logo-text {
    font-size: 1.45rem;
    font-weight: 700;
    color: var(--se-dark);
    letter-spacing: -0.5px;
  }

  .se-logo-text span {
    color: var(--se-brand);
  }

  /* ── Filter toggle button ── */
  .se-filter-toggle {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 9px 14px;
    border: 1.5px solid var(--se-border);
    border-radius: var(--se-radius);
    background: var(--se-white);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--se-dark);
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
    flex-shrink: 0;
    white-space: nowrap;
  }

  .se-filter-toggle:hover {
    background: var(--se-surface);
    border-color: #bbb;
  }

  .se-filter-toggle.active {
    border-color: var(--se-dark);
    background: var(--se-dark);
    color: var(--se-white);
  }

  .se-filter-badge {
    background: var(--se-brand);
    color: #fff;
    border-radius: 50%;
    width: 18px;
    height: 18px;
    font-size: 0.65rem;
    font-weight: 700;
    display: none;
    align-items: center;
    justify-content: center;
  }

  .se-filter-badge.show {
    display: flex;
  }

  /* ── Right Actions ── */
  .se-actions {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
  }

  .se-nav-link {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 9px 13px;
    border-radius: 24px;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--se-dark);
    text-decoration: none;
    transition: background 0.15s;
    white-space: nowrap;
  }

  .se-nav-link:hover {
    background: var(--se-surface);
  }

  /* Stays dropdown */
  .se-dropdown {
    position: relative;
  }

  .se-dropdown-trigger {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 9px 13px;
    border-radius: 24px;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--se-dark);
    background: none;
    border: none;
    cursor: pointer;
    transition: background 0.15s;
    white-space: nowrap;
  }

  .se-dropdown-trigger:hover {
    background: var(--se-surface);
  }

  .se-chevron {
    transition: transform 0.2s;
  }

  .se-dropdown:hover .se-chevron,
  .se-dropdown:focus-within .se-chevron {
    transform: rotate(180deg);
  }

  .se-dropdown-menu {
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%) translateY(-4px);
    background: var(--se-white);
    border: 1px solid var(--se-border);
    border-radius: 16px;
    box-shadow: var(--se-shadow-lg);
    min-width: 180px;
    padding: 8px;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.18s ease, transform 0.18s ease, visibility 0.18s;
    z-index: 300;
  }

  .se-dropdown:hover .se-dropdown-menu,
  .se-dropdown:focus-within .se-dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .se-dropdown-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 12px;
    border-radius: 10px;
    font-size: 0.84rem;
    font-weight: 500;
    color: var(--se-dark);
    text-decoration: none;
    transition: background 0.13s;
  }

  .se-dropdown-item:hover {
    background: var(--se-surface);
  }

  .se-dropdown-item svg {
    color: var(--se-muted);
    flex-shrink: 0;
  }

  /* Auth buttons */
  .se-btn-outline {
    padding: 9px 18px;
    border: 1.5px solid var(--se-border);
    border-radius: var(--se-radius);
    background: var(--se-white);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--se-dark);
    text-decoration: none;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
    white-space: nowrap;
  }

  .se-btn-outline:hover {
    background: var(--se-surface);
    border-color: #bbb;
  }

  .se-btn-primary {
    padding: 9px 20px;
    background: var(--se-brand);
    border: none;
    border-radius: var(--se-radius);
    font-size: 0.82rem;
    font-weight: 700;
    color: #fff;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.15s, transform 0.12s;
    white-space: nowrap;
  }

  .se-btn-primary:hover {
    background: var(--se-brand-dark);
    color: #fff;
  }

  /* User pill */
  .se-user-dropdown {
    position: relative;
  }

  .se-user-pill {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 6px 6px 14px;
    border: 1.5px solid var(--se-border);
    border-radius: var(--se-radius);
    background: var(--se-white);
    cursor: pointer;
    transition: box-shadow 0.15s;
    text-decoration: none;
    color: var(--se-dark);
    font-size: 0.82rem;
    font-weight: 600;
  }

  .se-user-pill:hover {
    box-shadow: var(--se-shadow);
  }

  .se-avatar {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: var(--se-dark);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .se-user-dropdown-menu {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    background: var(--se-white);
    border: 1px solid var(--se-border);
    border-radius: 16px;
    box-shadow: var(--se-shadow-lg);
    min-width: 200px;
    padding: 8px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: opacity 0.18s ease, transform 0.18s ease, visibility 0.18s;
    z-index: 300;
  }

  .se-user-dropdown:hover .se-user-dropdown-menu,
  .se-user-dropdown:focus-within .se-user-dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .se-user-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 12px;
    border-radius: 10px;
    font-size: 0.84rem;
    font-weight: 500;
    color: var(--se-dark);
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
    width: 100%;
    text-align: left;
    transition: background 0.13s;
  }

  .se-user-item:hover {
    background: var(--se-surface);
  }

  .se-user-item.logout {
    color: var(--se-brand);
    font-weight: 600;
  }

  .se-user-item.logout:hover {
    background: #fff0f2;
  }

  .se-sep {
    height: 1px;
    background: var(--se-border);
    margin: 6px 0;
  }

  /* ── Filter Panel ── */
  .se-filter-panel {
    border-top: 1px solid var(--se-border);
    background: var(--se-white);
    padding: 0;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1), padding 0.3s;
  }

  .se-filter-panel.open {
    max-height: 420px;
    padding: 20px 0 24px;
  }

  .se-filter-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .se-filter-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
    gap: 16px;
    margin-bottom: 20px;
  }

  .se-filter-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .se-filter-label {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--se-dark);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .se-filter-select,
  .se-filter-input {
    padding: 9px 12px;
    border: 1.5px solid var(--se-border);
    border-radius: 12px;
    font-size: 0.84rem;
    color: var(--se-dark);
    background: var(--se-white);
    font-family: 'Inter', sans-serif;
    outline: none;
    transition: border-color 0.15s;
    appearance: none;
    -webkit-appearance: none;
  }

  .se-filter-select:focus,
  .se-filter-input:focus {
    border-color: var(--se-dark);
  }

  .se-filter-select-wrap {
    position: relative;
  }

  .se-filter-select-wrap svg {
    position: absolute;
    right: 10px;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    color: var(--se-muted);
  }

  .se-filter-select {
    width: 100%;
    padding-right: 30px;
    cursor: pointer;
  }

  /* Price Range */
  .se-price-range {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .se-price-input {
    flex: 1;
    padding: 9px 10px;
    border: 1.5px solid var(--se-border);
    border-radius: 12px;
    font-size: 0.84rem;
    color: var(--se-dark);
    background: var(--se-white);
    font-family: 'Inter', sans-serif;
    outline: none;
    transition: border-color 0.15s;
    min-width: 0;
  }

  .se-price-input:focus {
    border-color: var(--se-dark);
  }

  .se-price-dash {
    color: var(--se-muted);
    font-size: 0.85rem;
    flex-shrink: 0;
  }

  /* Amenity chips */
  .se-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .se-chip {
    padding: 5px 12px;
    border: 1.5px solid var(--se-border);
    border-radius: 20px;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--se-muted);
    cursor: pointer;
    transition: all 0.15s;
    user-select: none;
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .se-chip:hover {
    border-color: var(--se-dark);
    color: var(--se-dark);
  }

  .se-chip.selected {
    border-color: var(--se-dark);
    background: var(--se-dark);
    color: #fff;
  }

  /* Filter footer */
  .se-filter-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 16px;
    border-top: 1px solid var(--se-border);
    gap: 12px;
    flex-wrap: wrap;
  }

  .se-filter-active-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    flex: 1;
  }

  .se-active-tag {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 4px 10px;
    background: #fff0f2;
    border: 1px solid #ffc2ce;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--se-brand);
  }

  .se-active-tag button {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    color: var(--se-brand);
    display: flex;
    align-items: center;
    line-height: 1;
    font-size: 12px;
  }

  .se-filter-actions {
    display: flex;
    gap: 8px;
  }

  .se-btn-clear {
    padding: 8px 16px;
    border: 1.5px solid var(--se-border);
    border-radius: var(--se-radius);
    background: var(--se-white);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--se-muted);
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
  }

  .se-btn-clear:hover {
    border-color: var(--se-dark);
    color: var(--se-dark);
  }

  .se-btn-apply {
    padding: 8px 20px;
    background: var(--se-brand);
    border: none;
    border-radius: var(--se-radius);
    font-size: 0.82rem;
    font-weight: 700;
    color: #fff;
    cursor: pointer;
    transition: background 0.15s;
    white-space: nowrap;
  }

  .se-btn-apply:hover {
    background: var(--se-brand-dark);
  }

  /* ── Mobile Toggle ── */
  .se-mobile-toggle {
    display: none;
    background: none;
    border: 1.5px solid var(--se-border);
    border-radius: 12px;
    padding: 8px 12px;
    cursor: pointer;
    align-items: center;
    gap: 8px;
    color: var(--se-dark);
    font-size: 0.82rem;
    font-weight: 600;
  }

  /* ── Mobile Drawer (Enhanced animations & padding) ── */
  .se-mobile-drawer {
    display: none;
    background: var(--se-white);
    padding: 0 16px;
    flex-direction: column;
    gap: 8px;
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease, padding 0.3s ease;
    border-top: 1px solid transparent;
  }

  .se-mobile-drawer.open {
    display: flex;
    max-height: 800px;
    opacity: 1;
    padding: 16px;
    border-top: 1px solid var(--se-border);
    box-shadow: inset 0 10px 15px -10px rgba(0,0,0,0.05);
  }

  .se-drawer-link {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 11px 14px;
    border-radius: 12px;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--se-dark);
    text-decoration: none;
    transition: background 0.13s;
  }

  .se-drawer-link:hover {
    background: var(--se-surface);
  }

  .se-drawer-link svg {
    color: var(--se-muted);
  }

  .se-drawer-link.highlight {
    color: var(--se-brand);
  }

  .se-drawer-link.highlight svg {
    color: var(--se-brand);
  }

  .se-drawer-sep {
    height: 1px;
    background: var(--se-border);
    margin: 6px 0;
  }

  .se-drawer-auth {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    margin-top: 4px;
  }

  .se-drawer-auth .se-btn-outline,
  .se-drawer-auth .se-btn-primary {
    text-align: center;
    display: block;
  }

  /* Mobile filter section */
  .se-mobile-filter-toggle {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 11px 14px;
    border: 1.5px solid var(--se-border);
    border-radius: 12px;
    background: none;
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--se-dark);
    width: 100%;
    margin-bottom: 4px;
    transition: background 0.15s;
  }

  .se-mobile-filter-toggle:hover {
    background: var(--se-surface);
  }

  .se-mobile-filter-body {
    display: none;
    flex-direction: column;
    gap: 14px;
    padding: 0 4px 8px;
  }

  .se-mobile-filter-body.open {
    display: flex;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {

    .se-actions,
    .se-filter-toggle {
      display: none !important;
    }

    .se-mobile-toggle {
      display: flex;
    }

    .se-mobile-drawer.open {
      display: flex;
    }

    .se-filter-panel {
      display: none;
    }
  }

  @media (max-width: 400px) {
    .se-logo-text {
      font-size: 1.25rem;
    }
  }
</style>

<!-- ════ NAVBAR ════ -->
<nav class="se-navbar">

  <div class="se-nav-top">

    <!-- Logo -->
    <a class="se-logo" href="/">
      <svg width="24" height="24" viewBox="0 0 32 32" fill="currentColor">
        <path
          d="M16 2C10.48 2 6 6.48 6 12c0 7.5 10 18 10 18s10-10.5 10-18c0-5.52-4.48-10-10-10zm0 13.5c-1.93 0-3.5-1.57-3.5-3.5S14.07 8.5 16 8.5s3.5 1.57 3.5 3.5-1.57 3.5-3.5 3.5z" />
      </svg>
      <span class="se-logo-text">Stay<span>Ease</span></span>
