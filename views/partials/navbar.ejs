<script>
  (function () {
    const filterToggle = document.getElementById('seFilterToggle');
    const filterPanel = document.getElementById('seFilterPanel');
    const filterBadge = document.getElementById('seFilterBadge');
    const activeTags = document.getElementById('seActiveTags');
    const clearBtn = document.getElementById('seClearBtn');
    const chips = document.querySelectorAll('.se-chip');
    const mobileToggle = document.getElementById('seToggle');
    const drawer = document.getElementById('seDrawer');
    const mobileFilterToggle = document.getElementById('seMobileFilterToggle');
    const mobileFilterBody = document.getElementById('seMobileFilterBody');
    const mobileChevron = document.getElementById('seMobileChevron');

    const filterFields = [
      { id: 'filterType', label: 'Type' },
      { id: 'filterMinPrice', label: 'Min ₹' },
      { id: 'filterMaxPrice', label: 'Max ₹' },
      { id: 'filterBedrooms', label: 'Beds' },
      { id: 'filterSort', label: 'Sort' },
      { id: 'filterRating', label: 'Rating' },
    ];

    let selectedAmenities = [];

    function updateBadgeAndTags() {
      let count = 0;
      activeTags.innerHTML = '';
      filterFields.forEach(f => {
        const el = document.getElementById(f.id);
        if (el && el.value) {
          count++;
          addTag(f.label + ': ' + el.value, () => { el.value = ''; updateBadgeAndTags(); });
        }
      });
      selectedAmenities.forEach(a => {
        count++;
        addTag(a, () => {
          selectedAmenities = selectedAmenities.filter(x => x !== a);
          chips.forEach(c => { if (c.dataset.value === a) c.classList.remove('selected'); });
          updateBadgeAndTags();
        });
      });
      filterBadge.textContent = count;
      if (count > 0) filterBadge.classList.add('show');
      else filterBadge.classList.remove('show');
    }

    function addTag(text, removeFn) {
      const tag = document.createElement('div');
      tag.className = 'se-active-tag';
      tag.innerHTML = `<span>${text}</span>`;
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.innerHTML = '&times;';
      btn.addEventListener('click', removeFn);
      tag.appendChild(btn);
      activeTags.appendChild(tag);
    }

    filterToggle.addEventListener('click', () => {
      filterPanel.classList.toggle('open');
      filterToggle.classList.toggle('active');
    });

    filterFields.forEach(f => {
      const el = document.getElementById(f.id);
      if (el) el.addEventListener('change', updateBadgeAndTags);
      if (el) el.addEventListener('input', updateBadgeAndTags);
    });

    chips.forEach(chip => {
      chip.addEventListener('click', () => {
        const val = chip.dataset.value;
        chip.classList.toggle('selected');
        if (chip.classList.contains('selected')) {
          if (!selectedAmenities.includes(val)) selectedAmenities.push(val);
        } else {
          selectedAmenities = selectedAmenities.filter(a => a !== val);
        }
        updateBadgeAndTags();
      });
    });

    clearBtn.addEventListener('click', () => {
      filterFields.forEach(f => { const el = document.getElementById(f.id); if (el) el.value = ''; });
      selectedAmenities = [];
      chips.forEach(c => c.classList.remove('selected'));
      updateBadgeAndTags();
    });

    mobileToggle.addEventListener('click', () => {
      drawer.classList.toggle('open');
    });

    if(mobileFilterToggle && mobileFilterBody && mobileChevron) {
      mobileFilterToggle.addEventListener('click', () => {
        mobileFilterBody.classList.toggle('open');
        mobileChevron.style.transform = mobileFilterBody.classList.contains('open') ? 'rotate(180deg)' : '';
      });
    }
  })();
</script>