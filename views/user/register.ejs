<% layout("/layouts/boilerplate.ejs") %>

<section class="container d-flex justify-content-center align-items-center py-5 min-vh-80">
    <div class="card border-0 shadow-lg overflow-hidden w-100" style="max-width: 1000px; border-radius: var(--radius-md) !important; background-color: #ffffff;">
        <div class="row g-0">
            
            <!-- Left Panel (Desktop Image) -->
            <div class="col-md-5 d-none d-md-block position-relative" style="background: url('https://images.unsplash.com/photo-1582719508461-905c673771fd?auto=format&fit=crop&w=1000&q=80') no-repeat center center; background-size: cover; min-height: 560px;">
                <div class="position-absolute inset-0 bg-gradient-to-t" style="background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.1) 100%); width:100%; height:100%; top:0; left:0;"></div>
                <div class="position-absolute bottom-0 start-0 p-5 text-white">
                    <h2 class="fw-extrabold mb-2 text-white" style="font-size: 2rem; letter-spacing: -0.5px;">Join StayEase</h2>
                    <p class="text-light opacity-90 mb-0">Create an account to book verified stays and access premium hosting tools.</p>
                </div>
            </div>

            <!-- Right Panel (Register Form) -->
            <div class="col-md-7 col-12 d-flex align-items-center">
                <div class="card-body p-4 p-md-5">
                    
                    <div class="mb-4 d-none d-md-block">
                        <h4 class="fw-extrabold mb-1" style="letter-spacing: -0.5px; color: var(--dark);">Create Account</h4>
                        <p class="text-muted small">Fill in the details below to register</p>
                    </div>

                    <div class="mb-4 d-md-none text-center">
                        <h3 class="fw-extrabold mb-1">Create Account</h3>
                        <p class="text-muted small">Register to book or host stays</p>
                    </div>

                    <form action="/user/register" method="POST" class="validated-form" novalidate>
                        
                        <div class="row">
                            <!-- Username -->
                            <div class="col-sm-6 mb-3">
                                <label class="form-label fw-bold">Username</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-user text-muted"></i></span>
                                    <input
                                        type="text"
                                        name="username"
                                        class="form-control border-start-0"
                                        placeholder="Username"
                                        required
                                        style="padding-left: 0;"
                                    >
                                    <div class="invalid-feedback">Please enter a username.</div>
                                </div>
                            </div>

                            <!-- Email -->
                            <div class="col-sm-6 mb-3">
                                <label class="form-label fw-bold">Email Address</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-envelope text-muted"></i></span>
                                    <input
                                        type="email"
                                        name="email"
                                        class="form-control border-start-0"
                                        placeholder="name@example.com"
                                        required
                                        style="padding-left: 0;"
                                    >
                                    <div class="invalid-feedback">Please enter a valid email.</div>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <!-- Password -->
                            <div class="col-sm-6 mb-3">
                                <label class="form-label fw-bold">Password</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-lock text-muted"></i></span>
                                    <input
                                        type="password"
                                        name="password"
                                        class="form-control border-start-0"
                                        placeholder="Create password"
                                        required
                                        style="padding-left: 0;"
                                    >
                                    <div class="invalid-feedback">Please enter a password.</div>
                                </div>
                            </div>

                            <!-- Phone -->
                            <div class="col-sm-6 mb-3">
                                <label class="form-label fw-bold">Phone Number</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-phone text-muted"></i></span>
                                    <input
                                        type="text"
                                        name="phone"
                                        class="form-control border-start-0"
                                        placeholder="+91 9876543210"
                                        required
                                        style="padding-left: 0;"
                                    >
                                    <div class="invalid-feedback">Please enter your phone number.</div>
                                </div>
                            </div>
                        </div>

                        <!-- Role Selection -->
                        <div class="mb-4">
                            <label class="form-label fw-bold">Register As</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-id-card text-muted"></i></span>
                                <select
                                    name="role"
                                    class="form-select border-start-0"
                                    required
                                    style="padding-left: 0; cursor: pointer;"
                                >
                                    <option value="user" selected>Guest (I want to book stays)</option>
                                    <option value="host">Host (I want to rent out properties)</option>
                                </select>
                                <div class="invalid-feedback">Please choose your account type.</div>
                            </div>
                        </div>

                        <!-- Submit Button -->
                        <button type="submit" class="btn btn-dark btn-lg w-100 rounded-pill py-3 shadow mb-3">
                            <i class="fa-solid fa-user-plus me-2"></i>Create Account
                        </button>

                    </form>

                    <div class="text-center mt-2">
                        <small class="text-muted">
                            Already have an account? 
                            <a href="/user/login" class="text-primary fw-bold text-decoration-none hover-primary">
                                Login instead
                            </a>
                        </small>
                    </div>

                </div>
            </div>

        </div>
    </div>
</section>

<script>
    (() => {
        'use strict'
        const forms = document.querySelectorAll('.validated-form')
        Array.from(forms).forEach(form => {
            form.addEventListener('submit', event => {
                if (!form.checkValidity()) {
                    event.preventDefault()
                    event.stopPropagation()
                }
                form.classList.add('was-validated')
            }, false)
        })
    })()
</script>