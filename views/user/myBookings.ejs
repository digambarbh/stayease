<% layout("/layouts/boilerplate.ejs") %>

<section class="container py-5">

    <div class="mb-5 text-center">
        <h1 class="fw-bold mb-2">My Bookings</h1>
        <p class="text-muted mb-0">Review your booked stays with quick access to details and availability.</p>
    </div>

    <div class="row g-4">

        <% for(let stay of stays) { %>

            <div class="col-sm-6 col-lg-4">

                <div class="card booking-card h-100 overflow-hidden border-0">

                    <div class="position-relative booking-image-wrapper">
                        <img
                            src="<%= (stay.images && stay.images[0]) ? stay.images[0].url : 'https://via.placeholder.com/800x600?text=No+image' %>"
                            class="booking-image"
                            alt="stay image"
                        >
                        <span class="booking-status badge rounded-pill <%= stay.isAvailable ? 'bg-success' : 'bg-danger' %>">
                            <%= stay.isAvailable ? 'Available' : 'Booked' %>
                        </span>
                    </div>

                    <div class="card-body d-flex flex-column gap-3">

                        <div>
                            <h5 class="booking-title fw-bold mb-2"><%= stay.name %></h5>
                            <p class="text-muted mb-1">
                                📍 <%= stay.location %>
                            </p>
                            <p class="text-secondary small mb-0 booking-description">
                                <%= stay.description.substring(0, 90) %>...
                            </p>
                        </div>

                        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 booking-meta">
                            <span class="badge booking-tag bg-light text-dark border py-2 px-3">
                                <%= stay.type %>
                            </span>
                            <span class="text-muted small">
                                👥 <%= stay.capacity %> Guests
                            </span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-auto">
                            <div>
                                <div class="booking-price fw-bold">₹<%= stay.price %></div>
                                <small class="text-muted">/ night</small>
                            </div>
                            <a href="/user/my/bookings/<%= stay._id %>" class="btn btn-dark booking-button rounded-pill px-4 py-2">
                                View Details
                            </a>
                        </div>

                    </div>

                </div>

            </div>

        <% } %>

    </div>

</section>

<style>

.booking-card {
    border-radius: 28px;
    box-shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
    overflow: hidden;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
}

.booking-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 24px 60px rgba(15, 23, 42, 0.14);
}

.booking-image-wrapper {
    overflow: hidden;
    position: relative;
}

.booking-image {
    width: 100%;
    height: 240px;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
}

.booking-card:hover .booking-image {
    transform: scale(1.04);
}

.booking-status {
    position: absolute;
    top: 16px;
    right: 16px;
    padding: 0.5rem 0.9rem;
    font-size: 0.8rem;
    font-weight: 700;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
}

.booking-title {
    font-size: 1.1rem;
    line-height: 1.3;
}

.booking-description {
    min-height: 3.2rem;
}

.booking-meta {
    border-top: 1px solid #f1f1f1;
    padding-top: 1rem;
}

.booking-tag {
    font-size: 0.85rem;
    border-radius: 999px;
}

.booking-price {
    font-size: 1.3rem;
    color: #111827;
}

.booking-button {
    font-weight: 600;
    letter-spacing: 0.01em;
}

@media (max-width: 768px) {
    .booking-image {
        height: 220px;
    }
}

</style>
