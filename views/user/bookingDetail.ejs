<% layout("/layouts/boilerplate.ejs") %>
<style>
  body {
    background-color: #f7f9fa; /* Slight off-white background to make tickets pop */
  }

  .page-header {
    margin: 3rem 0;
    text-align: center;
  }

  .page-header h2 {
    font-size: 2.8rem;
    font-weight: 900;
    color: #222222;
    letter-spacing: -0.04em;
    margin: 0;
  }

  .page-header p {
    color: #717171;
    font-size: 1.1rem;
    margin-top: 0.5rem;
  }

  .bookings-container {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding-bottom: 5rem;
    max-width: 900px;
    margin: 0 auto;
  }

  /* Empty State */
  .empty-state {
    text-align: center;
    padding: 6rem 2rem;
    background: #ffffff;
    border-radius: 32px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.03);
    margin: 2rem auto 4rem;
    max-width: 600px;
    border: 1px solid rgba(0,0,0,0.02);
  }

  .empty-icon {
    font-size: 4rem;
    margin-bottom: 1.5rem;
    display: inline-block;
    animation: float 3s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
  }

  .empty-state h3 {
    font-size: 2.2rem;
    font-weight: 800;
    color: #222222;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .empty-state p {
    font-size: 1.1rem;
    color: #717171;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
  }

  .explore-btn {
    background: linear-gradient(135deg, #FF385C 0%, #E61E4D 50%, #D70466 100%);
    color: white;
    padding: 16px 40px;
    border-radius: 50px;
    font-weight: 700;
    font-size: 1.1rem;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    display: inline-block;
    box-shadow: 0 8px 20px rgba(227, 28, 95, 0.3);
  }

  .explore-btn:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 25px rgba(227, 28, 95, 0.4);
    color: white;
  }

  /* Ticket Structure */
  .booking-ticket {
    background: #ffffff;
    border-radius: 20px;
    display: flex;
    position: relative;
    box-shadow: 0 15px 35px rgba(0,0,0,0.06);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    overflow: hidden;
  }

  .booking-ticket:hover {
    transform: translateY(-6px);
    box-shadow: 0 25px 50px rgba(0,0,0,0.1);
  }

  /* Left Side of Ticket */
  .ticket-main {
    flex: 1;
    padding: 2.5rem;
    position: relative;
    border-right: 2px dashed #ebebeb;
  }

  /* Right Side of Ticket */
  .ticket-stub {
    width: 320px;
    background: #fdfdfd;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
  }

  /* Cutout Circles for the ticket look */
  .booking-ticket::before,
  .booking-ticket::after {
    content: '';
    position: absolute;
    width: 40px;
    height: 40px;
    background-color: #f7f9fa; /* Matches body background */
    border-radius: 50%;
    right: 300px; /* 320px (stub width) - 20px (half circle) */
    z-index: 2;
  }

  .booking-ticket::before {
    top: -20px;
    box-shadow: inset 0 -4px 6px rgba(0,0,0,0.02);
  }

  .booking-ticket::after {
    bottom: -20px;
    box-shadow: inset 0 4px 6px rgba(0,0,0,0.02);
  }

  /* Ticket Main Content */
  .ticket-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }

  .status-badge {
    padding: 8px 18px;
    border-radius: 12px;
    font-size: 0.85rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .status-badge.approved { background: #ecfdf5; color: #059669; }
  .status-badge.pending { background: #fffbeb; color: #d97706; }
  .status-badge.rejected { background: #fef2f2; color: #dc2626; }
  .status-badge.cancelled { background: #f3f4f6; color: #4b5563; }

  .ticket-price {
    font-size: 2rem;
    font-weight: 900;
    color: #222;
    letter-spacing: -0.03em;
  }

  .ticket-route {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: #f8f9fa;
    padding: 1.5rem 2rem;
    border-radius: 16px;
    margin-bottom: 2rem;
  }

  .route-point {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .route-point.end {
    text-align: right;
  }

  .route-point small {
    font-size: 0.8rem;
    color: #717171;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .route-point h4 {
    margin: 0;
    font-size: 1.4rem;
    font-weight: 800;
    color: #222;
  }

  .route-divider {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 1.5rem;
    position: relative;
  }

  .route-line {
    width: 100%;
    height: 2px;
    background: #ebebeb;
    position: relative;
  }

  .route-line::after {
    content: '✈️';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: #f8f9fa;
    padding: 0 10px;
    font-size: 1.2rem;
  }

  .ticket-details {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .detail-block {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .detail-block small {
    font-size: 0.75rem;
    color: #717171;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .detail-block strong {
    font-size: 1.2rem;
    color: #222;
    font-weight: 800;
  }

  /* Ticket Stub Content */
  .stub-row {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 1.5rem;
  }

  .stub-row:last-child {
    margin-bottom: 0;
  }

  .stub-row small {
    font-size: 0.7rem;
    color: #888;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .stub-row .mono-text {
    font-family: 'Courier New', Courier, monospace;
    font-size: 1.1rem;
    font-weight: 700;
    color: #222;
    background: #f0f2f5;
    padding: 6px 12px;
    border-radius: 8px;
    display: inline-block;
    word-break: break-all;
  }

  .stub-row strong {
    font-size: 1rem;
    color: #222;
    font-weight: 700;
  }

  /* Responsive Design */
  @media (max-width: 900px) {
    .booking-ticket {
      flex-direction: column;
    }
    .ticket-main {
      border-right: none;
      border-bottom: 2px dashed #ebebeb;
    }
    .ticket-stub {
      width: 100%;
      padding: 2rem 2.5rem;
    }
    .booking-ticket::before,
    .booking-ticket::after {
      right: auto;
      left: 50%;
      transform: translateX(-50%);
    }
    .booking-ticket::before { top: auto; bottom: 250px; } /* Adjust based on stub height */
    .booking-ticket::after { display: none; } /* On mobile, maybe hide the bottom cutout or reposition */
    /* Let's just hide the cutouts on mobile for simplicity */
    .booking-ticket::before, .booking-ticket::after { display: none; }
  }

  @media (max-width: 600px) {
    .ticket-main, .ticket-stub {
      padding: 1.5rem;
    }
    .ticket-route {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }
    .route-point.end {
      text-align: center;
    }
    .route-divider {
      width: 100%;
      padding: 1rem 0;
    }
    .route-line::after {
      transform: translate(-50%, -50%) rotate(90deg);
    }
    .ticket-details {
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }
    .ticket-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
    .ticket-price {
      font-size: 1.6rem;
    }
  }
</style>

<div class="container mt-4 mb-5">
<% if(bookings.length === 0){ %>
    <div class="empty-state">
        <div class="empty-icon">🎫</div>
        <h3>No Tickets Yet</h3>
        <p>Your upcoming itinerary will appear here. Find your perfect destination and start packing!</p>
        <a href="/stays" class="explore-btn">Explore Destinations</a>
    </div>
<% } else { %>
    <div class="page-header">
        <h2>Your Itinerary</h2>
        <p>All your upcoming and past trips in one place</p>
    </div>

    <div class="bookings-container">
        <% bookings.forEach(booking => { %>
        <div class="booking-ticket">
            
            <!-- Left Side: Main Info -->
            <div class="ticket-main">
                <div class="ticket-header">
                    <div class="status-badge <%= booking.status %>">
                        <% if(booking.status === 'approved') { %> ✓ <% } %>
                        <% if(booking.status === 'pending') { %> ⏳ <% } %>
                        <% if(booking.status === 'rejected') { %> ✕ <% } %>
                        <%= booking.status %>
                    </div>
                    <div class="ticket-price">₹<%= booking.totalPrice.toLocaleString("en-IN") %></div>
                </div>

                <div class="ticket-route">
                    <div class="route-point">
                        <small>Check-in</small>
                        <h4><%= new Date(booking.checkIn).toLocaleDateString('en-IN',{ day:'numeric', month:'short' }) %></h4>
                        <small style="color: #222; margin-top: 4px;"><%= new Date(booking.checkIn).getFullYear() %></small>
                    </div>
                    
                    <div class="route-divider">
                        <div class="route-line"></div>
                    </div>

                    <div class="route-point end">
                        <small>Check-out</small>
                        <h4><%= new Date(booking.checkOut).toLocaleDateString('en-IN',{ day:'numeric', month:'short' }) %></h4>
                        <small style="color: #222; margin-top: 4px;"><%= new Date(booking.checkOut).getFullYear() %></small>
                    </div>
                </div>

                <div class="ticket-details">
                    <div class="detail-block">
                        <small>Guests</small>
                        <strong><%= booking.guests %></strong>
                    </div>
                    <div class="detail-block">
                        <small>Duration</small>
                        <strong><%= booking.nights %> Nights</strong>
                    </div>
                    <div class="detail-block">
                        <small>Payment</small>
                        <strong><span style="text-transform: capitalize;"><%= booking.payment.status %></span></strong>
                    </div>
                </div>
            </div>

            <!-- Right Side: Stub -->
            <div class="ticket-stub">
                <div class="stub-row">
                    <small>Booking ID</small>
                    <span class="mono-text"><%= booking._id.toString().slice(-8).toUpperCase() %></span>
                </div>
                <div class="stub-row">
                    <small>Transaction ID</small>
                    <span class="mono-text" style="font-size: 0.9rem;"><%= booking.payment.razorpayOrderId || 'N/A' %></span>
                </div>
                <div class="stub-row">
                    <small>Payment Method</small>
                    <strong><%= booking.payment.razorpayPaymentId ? 'Razorpay Gateway' : 'Pending Verification' %></strong>
                </div>
                <div class="stub-row" style="margin-top: 1rem; border-top: 1px solid #ebebeb; padding-top: 1rem;">
                    <small>Booked On</small>
                    <strong><%= new Date(booking.createdAt).toLocaleDateString('en-IN', { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' }) %></strong>
                </div>
            </div>

        </div>
        <% }) %>
    </div>
<% } %>
</div>
