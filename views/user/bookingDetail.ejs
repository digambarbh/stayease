<% layout("/layouts/boilerplate.ejs") %>
<style>
  .bookings-container {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 2rem;
    padding: 2rem 0;
  }

  .booking-card {
    background: #ffffff;
    border: 1px solid #e5e5e5;
    border-radius: 24px;
    padding: 1.5rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    display: flex;
    flex-direction: column;
    height: 100%;
    box-sizing: border-box;
    overflow: hidden;
  }

  .booking-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.1);
  }

  .booking-top {
    display: flex;
    justify-content: space-between;
    align-items: start;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .status-pill {
    display: inline-block;
    padding: 0.5rem 1rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    white-space: nowrap;
  }

  .status-pill.approved {
    background: rgba(34, 197, 94, 0.12);
    color: #22c55e;
  }

  .status-pill.pending {
    background: rgba(234, 179, 8, 0.12);
    color: #eab308;
  }

  .status-pill.rejected {
    background: rgba(239, 68, 68, 0.12);
    color: #ef4444;
  }

  .status-pill.cancelled {
    background: rgba(107, 114, 128, 0.12);
    color: #6b7280;
  }

  .booking-price {
    font-size: 1.5rem;
    font-weight: 700;
    color: #222222;
    white-space: nowrap;
  }

  .stay-dates {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding: 1rem;
    background: #f9f9f9;
    border-radius: 16px;
  }

  .date-box {
    flex: 1;
    min-width: 0;
  }

  .date-box small {
    display: block;
    font-size: 0.7rem;
    color: #717171;
    font-weight: 600;
    text-transform: uppercase;
    margin-bottom: 0.4rem;
    letter-spacing: 0.3px;
  }

  .date-box h4 {
    margin: 0;
    font-size: 1.2rem;
    font-weight: 700;
    color: #222222;
  }

  .date-divider {
    flex: 0 0 auto;
    font-size: 1.2rem;
    color: #dddddd;
    padding: 0 0.5rem;
  }

  .booking-info {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid #e5e5e5;
  }

  .info-item {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .info-item span {
    font-size: 0.75rem;
    color: #717171;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    margin-bottom: 0.4rem;
  }

  .info-item strong {
    font-size: 1.1rem;
    color: #222222;
    font-weight: 700;
    word-break: break-word;
  }

  .booking-footer {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid #e5e5e5;
  }

  .booking-footer-row {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .footer-item {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .footer-item small {
    font-size: 0.75rem;
    color: #717171;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    margin-bottom: 0.4rem;
  }

  .footer-item strong {
    font-size: 1rem;
    color: #222222;
    font-weight: 600;
    word-break: break-word;
    overflow-wrap: anywhere;
  }

  /* Tablets */
  @media (max-width: 1024px) {
    .bookings-container {
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 1.5rem;
    }
  }

  /* Small tablets / large phones */
  @media (max-width: 768px) {
    .bookings-container {
      grid-template-columns: 1fr;
      gap: 1.25rem;
      padding: 1.5rem 0;
    }

    .booking-card {
      padding: 1.25rem;
      border-radius: 18px;
    }

    .stay-dates {
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .date-divider {
      width: 100%;
      text-align: center;
      padding: 0.25rem 0;
    }

    .booking-info {
      grid-template-columns: repeat(2, 1fr);
    }

    .booking-footer-row {
      grid-template-columns: 1fr;
    }
  }

  /* Small phones */
  @media (max-width: 420px) {
    .booking-card {
      padding: 1rem;
      border-radius: 14px;
    }

    .booking-top {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }

    .booking-price {
      font-size: 1.25rem;
    }

    .stay-dates {
      padding: 0.75rem;
    }

    .date-box h4 {
      font-size: 1rem;
    }

    .booking-info {
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
    }

    .info-item strong {
      font-size: 1rem;
    }

    .footer-item strong {
      font-size: 0.9rem;
    }
  }
</style>

<% if(bookings.length === 0){ %>

<div class="text-center py-5">
    <h3>No bookings yet</h3>
    <p class="text-muted">
        Your upcoming stays will appear here.
    </p>
</div>

<% } else { %>

<div class="bookings-container">
    <% bookings.forEach(booking => { %>

<div class="booking-card">

    <div class="booking-top">
        <div>
            <span class="status-pill <%= booking.status %>">
                <%= booking.status %>
            </span>
        </div>

        <div class="booking-price">
            ₹<%= booking.totalPrice.toLocaleString("en-IN") %>
        </div>
    </div>

    <div class="stay-dates">
        <div class="date-box">
            <small>CHECK-IN</small>
            <h4>
                <%= new Date(booking.checkIn).toLocaleDateString('en-IN',{
                    day:'numeric',
                    month:'short'
                }) %>
            </h4>
        </div>

        <div class="date-divider">→</div>

        <div class="date-box">
            <small>CHECK-OUT</small>
            <h4>
                <%= new Date(booking.checkOut).toLocaleDateString('en-IN',{
                    day:'numeric',
                    month:'short'
                }) %>
            </h4>
        </div>
    </div>

    <div class="booking-info">
        <div class="info-item">
            <span>Guests</span>
            <strong><%= booking.guests %></strong>
        </div>

        <div class="info-item">
            <span>Nights</span>
            <strong><%= booking.nights %></strong>
        </div>

        <div class="info-item">
            <span>Payment</span>
            <strong><%= booking.payment.status %></strong>
        </div>
    </div>

    <div class="booking-footer">
        <div class="booking-footer-row">
            <div class="footer-item">
                <small>Booked On</small>
                <strong><%= new Date(booking.createdAt).toLocaleDateString() %></strong>
            </div>
            <div class="footer-item">
                <small>Booking ID</small>
                <strong><%= booking._id.toString().slice(-8).toUpperCase() %></strong>
            </div>
        </div>
        <div class="booking-footer-row">
            <div class="footer-item">
                <small>Order ID</small>
                <strong><%= booking.payment.razorpayOrderId || 'N/A' %></strong>
            </div>
            <div class="footer-item">
                <small>Payment Method</small>
                <strong><%= booking.payment.razorpayPaymentId ? 'Razorpay' : 'Pending' %></strong>
            </div>
        </div>
    </div>

</div>

    <% }) %>
</div>

<% } %>
