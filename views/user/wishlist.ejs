<% layout("/layouts/boilerplate.ejs") %>

<style>
    /* Premium Airbnb Stay Cards (from stays.ejs) */
    .stay-card {
        border: none !important;
        border-radius: 0 !important;
        overflow: visible;
        background-color: transparent !important;
        box-shadow: none !important;
        transition: none !important;
        position: relative;
    }
    .stay-card:hover {
        transform: none !important;
        box-shadow: none !important;
        border-color: transparent !important;
    }
    .card-img-top {
        border-radius: 12px !important;
        height: 280px !important;
        object-fit: cover;
        margin-bottom: 12px;
        transition: none !important;
    }
    .stay-card:hover .card-img-top {
        transform: none !important;
    }
    .stay-card .card-body {
        padding: 0 !important;
    }
    .stay-card .d-flex.justify-content-between.align-items-start.mb-2 {
        margin-bottom: 0 !important;
    }
    .stay-card h5.fw-bold {
        color: #222222;
        font-size: 1rem;
        font-weight: 600 !important;
        line-height: 1.2;
        margin-bottom: 2px !important;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 80%;
    }
    .stay-card p.text-muted {
        font-size: 0.95rem;
        font-weight: 400;
        color: #717171 !important;
        margin-bottom: 2px !important;
    }
    .stay-card .text-secondary.small {
        font-size: 0.95rem;
        color: #717171 !important;
        margin-bottom: 2px !important;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        line-height: 1.2;
    }
    .stay-card .d-flex.justify-content-between.mb-3 {
        border-top: none;
        padding-top: 0;
        margin-bottom: 8px !important;
        justify-content: flex-start !important;
        gap: 8px;
    }
    .stay-card .badge {
        font-size: 0.95rem;
        padding: 0;
        font-weight: 400;
        border-radius: 0 !important;
        background: transparent !important;
        border: none !important;
        color: #717171 !important;
        letter-spacing: 0;
    }
    .stay-card .badge::after {
        content: " • ";
        margin-left: 8px;
        color: #717171;
    }
    .stay-card .d-flex.mb-3 .text-muted.small {
        font-size: 0.95rem;
        font-weight: 400;
        color: #717171 !important;
    }
    .stay-card .d-flex.justify-content-between.align-items-center {
        justify-content: flex-start !important;
        margin-top: 4px;
    }
    .stay-card span.fw-bold.fs-5 {
        font-size: 1rem !important;
        font-weight: 600 !important;
        color: #222222;
        letter-spacing: 0;
    }
    .stay-card .align-items-center .text-muted.small {
        font-size: 1rem !important;
        color: #222222 !important;
        font-weight: 400 !important;
        margin-left: 4px;
    }
    .stay-card .card-body .btn-dark {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        opacity: 0;
        z-index: 10;
        cursor: pointer;
        padding: 0 !important;
        border: none !important;
        border-radius: 0 !important;
    }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 5rem 2rem;
        background: #ffffff;
        border-radius: 24px;
        margin: 2rem auto;
        max-width: 600px;
        border: 1px solid rgba(0,0,0,0.05);
    }
    .empty-icon {
        font-size: 3.5rem;
        margin-bottom: 1rem;
        display: inline-block;
    }
    .empty-state h3 {
        font-size: 1.8rem;
        font-weight: 800;
        color: #222;
        margin-bottom: 0.5rem;
    }
    .empty-state p {
        color: #717171;
        margin-bottom: 2rem;
        font-size: 1.05rem;
    }
    
    .page-title {
        font-size: 2rem;
        font-weight: 700;
        color: #222222;
        letter-spacing: -0.02em;
    }
</style>

<div class="container py-5">
    
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="page-title mb-1">Your Wishlist</h1>
            <p class="text-muted mb-0">Stays you've saved for later.</p>
        </div>
    </div>

    <% if (wishlist && wishlist.length > 0) { %>
        <div class="row g-4">
            <% for(let stay of wishlist) { %>
                <div class="col-sm-6 col-md-4 col-lg-3">
                    <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 stay-card">
                        <!-- Image -->
                        <img src="<%= (stay.images && stay.images[0]) ? stay.images[0].url : 'https://via.placeholder.com/800x600?text=No+image' %>"
                            class="card-img-top" alt="stay image" style="object-fit: cover;">
                        
                        <!-- Card Body -->
                        <div class="card-body d-flex flex-column">
                            
                            <!-- Top -->
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="fw-bold mb-0">
                                    <%= stay.name %>
                                </h5>
                                <% if(stay.isAvailable) { %>
                                    <span class="badge bg-success rounded-pill">Available</span>
                                <% } else { %>
                                    <span class="badge bg-danger rounded-pill">Booked</span>
                                <% } %>
                            </div>

                            <!-- Location -->
                            <p class="text-muted mb-2">
                                📍 <%= stay.location %>
                            </p>

                            <!-- Description -->
                            <p class="text-secondary small flex-grow-1">
                                <%= stay.description ? stay.description.substring(0, 90) + '...' : '' %>
                            </p>

                            <!-- Type & Capacity -->
                            <div class="d-flex justify-content-between mb-3">
                                <span class="badge bg-light text-dark border">
                                    <%= stay.type || 'Villa' %>
                                </span>
                                <span class="text-muted small">
                                    👥 <%= stay.capacity || 2 %> Guests
                                </span>
                            </div>

                            <!-- Bottom -->
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="fw-bold fs-5">
                                        ₹<%= stay.price %>
                                    </span>
                                    <span class="text-muted small">
                                        / night
                                    </span>
                                </div>
                                <a href="/stays/<%= stay._id %>" class="btn btn-dark rounded-pill px-4">
                                    View
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            <% } %>
        </div>
    <% } else { %>
        <div class="empty-state">
            <div class="empty-icon">❤️</div>
            <h3>Nothing saved yet</h3>
            <p>Tap the heart on any stay to start saving your favorites here.</p>
            <a href="/stays" class="btn btn-dark rounded-pill px-4 py-2" style="font-weight: 600;">
                Start Exploring
            </a>
        </div>
    <% } %>
</div>
