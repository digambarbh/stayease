<% layout("/layouts/boilerplate.ejs") %>

<section class="py-5">
  <div class="container">
    <div class="row align-items-center gy-4">
      <div class="col-lg-6">
        <span class="badge rounded-pill bg-danger px-3 py-2 mb-3">StayEase · Book smarter</span>
        <h1 class="display-5 fw-bold">Find relaxing stays, comfortable homes, and local experiences across India.</h1>
        <p class="lead text-muted my-4">Search verified hotels, cozy homestays, and modern villas with instant booking, secure payments, and 24/7 guest support.</p>
        <div class="d-flex flex-column flex-sm-row gap-3">
          <a href="/stays" class="btn btn-primary btn-lg">Browse stays</a>
          <a href="/user/register" class="btn btn-outline-secondary btn-lg">Create an account</a>
        </div>
      </div>
      <div class="col-lg-6 text-center">
        <div class="border rounded-4 p-4 bg-white shadow-sm">
          <img src="https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?auto=format&fit=crop&w=900&q=80" alt="StayEase hero" class="img-fluid rounded-4">
        </div>
      </div>
    </div>
  </div>
</section>

<section class="py-5 bg-light">
  <div class="container">
    <div class="row text-center mb-5">
      <div class="col-lg-8 mx-auto">
        <h2 class="fw-bold">Travel plans made easy</h2>
        <p class="text-muted">Choose from a wide variety of properties, book with confidence, and manage your reservations from one place.</p>
      </div>
    </div>
    <div class="row g-4">
      <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body">
            <div class="mb-3 display-6 text-danger">🏨</div>
            <h5 class="card-title fw-bold">Verified stays</h5>
            <p class="card-text text-muted">All of our listings are reviewed so you can book with confidence.</p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body">
            <div class="mb-3 display-6 text-danger">⚡</div>
            <h5 class="card-title fw-bold">Fast booking</h5>
            <p class="card-text text-muted">Reserve stays quickly with easy checkout and secure payment support.</p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body">
            <div class="mb-3 display-6 text-danger">💬</div>
            <h5 class="card-title fw-bold">Support anytime</h5>
            <p class="card-text text-muted">Need help? Our guest support team is available when you need it.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="py-5">
  <div class="container">
    <div class="row align-items-center gy-4">
      <div class="col-lg-6 order-lg-2">
        <h2 class="fw-bold">Discover stays for every trip</h2>
        <p class="text-muted">From weekend getaways to extended stays, find the right place with transparent pricing and real availability.</p>
        <ul class="list-unstyled text-dark fw-semibold">
          <li class="mb-3">✔️ Hotels near top attractions</li>
          <li class="mb-3">✔️ Family-friendly homestays</li>
          <li class="mb-3">✔️ Comfortable villas for groups</li>
        </ul>
        <a href="/stays" class="btn btn-outline-primary btn-lg">Explore stays</a>
      </div>
      <div class="col-lg-6 order-lg-1">
        <div class="row g-3">
          <div class="col-6">
            <img src="https://images.unsplash.com/photo-1494526585095-c41746248156?auto=format&fit=crop&w=600&q=80" alt="Cozy room" class="img-fluid rounded-4 shadow-sm">
          </div>
          <div class="col-6">
            <img src="https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?auto=format&fit=crop&w=600&q=80" alt="City stay" class="img-fluid rounded-4 shadow-sm">
          </div>
          <div class="col-12 mt-3">
            <img src="https://images.unsplash.com/photo-1512917774080-9991f1c4c750?auto=format&fit=crop&w=900&q=80" alt="Sunset stay" class="img-fluid rounded-4 shadow-sm">
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
